from pathlib import Path
import json

from fastapi import APIRouter, HTTPException


router = APIRouter(prefix="/analysis", tags=["analysis"])

PROJECT_ROOT = Path(__file__).resolve().parents[2]
RESULT_ROOT = PROJECT_ROOT / "data" / "results"


@router.get("/_health")
def health():
    return {"status": "ok"}


@router.get("/{audio_id}")
def get_analysis_result(audio_id: str):
    result_path = RESULT_ROOT / audio_id / "10_final_result.json"

    if not result_path.exists():
        raise HTTPException(
            status_code=404,
            detail=f"final result not found for audio_id={audio_id}"
        )

    try:
        with open(result_path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except json.JSONDecodeError:
        raise HTTPException(
            status_code=500,
            detail=f"invalid json: {result_path}"
        )

    return data
