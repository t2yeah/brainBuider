let samples = [];
let current = 0;
let analysisTimer = null;

const STEP_DEFS = [
  {
    key: "step-1",
    label: "音声読み込み",
    log: "audio loaded"
  },
  {
    key: "step-2",
    label: "音イベント解析",
    log: "panns labels detected"
  },
  {
    key: "step-3",
    label: "空間理解",
    log: "clap scene inferred"
  },
  {
    key: "step-4",
    label: "漫画プロンプト生成",
    log: "prompt generated"
  },
  {
    key: "step-5",
    label: "画像生成",
    log: "image rendering completed"
  }
];

function $(id) {
  return document.getElementById(id);
}

function escapeHtml(value) {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function appendLog(message) {
  const log = $("log");
  const now = new Date();
  const hh = String(now.getHours()).padStart(2, "0");
  const mm = String(now.getMinutes()).padStart(2, "0");
  const ss = String(now.getSeconds()).padStart(2, "0");

  const line = document.createElement("div");
  line.textContent = `[${hh}:${mm}:${ss}] ${message}`;
  log.appendChild(line);
  log.scrollTop = log.scrollHeight;
}

function clearLog() {
  const log = $("log");
  log.innerHTML = "";
}

function setProgress(value) {
  const safeValue = Math.max(0, Math.min(100, value));
  $("progress").style.width = `${safeValue}%`;
  $("progressText").innerText = `${safeValue}%`;
}

function resetStatuses() {
  for (let i = 1; i <= STEP_DEFS.length; i++) {
    const el = $(`status-step-${i}`);
    if (!el) continue;
    el.className = "status waiting";
    el.innerText = "待機";
  }
}

function setStepStatus(index, statusText, className) {
  const el = $(`status-step-${index}`);
  if (!el) return;
  el.className = `status ${className}`;
  el.innerText = statusText;
}

function normalizeArray(value) {
  if (Array.isArray(value)) return value;
  if (value == null) return [];
  return [value];
}

function renderLabels(labels) {
  const container = $("labels");
  const safeLabels = normalizeArray(labels);

  if (safeLabels.length === 0) {
    container.innerHTML = `<span class="chip">データなし</span>`;
    return;
  }

  container.innerHTML = safeLabels
    .map(label => `<span class="chip">${escapeHtml(label)}</span>`)
    .join("");
}

function renderOnomatopoeia(items) {
  const safeItems = normalizeArray(items);
  if (safeItems.length === 0) {
    $("onomatopoeia").innerText = "-";
    return;
  }
  $("onomatopoeia").innerText = safeItems.join(" / ");
}

function updateAudioSource(audioPath) {
  const audio = $("audio");
  audio.pause();
  audio.src = audioPath || "";
  audio.load();
}

function showSample(index) {
  if (!samples.length) {
    appendLog("samples.json にデータがありません");
    return;
  }

  current = index;
  const s = samples[current];

  $("sampleTitle").innerText = s.title || s.id || "untitled";
  $("image").src = s.image || "";
  $("image").alt = (s.title || s.id || "sample") + " の漫画画像";

  updateAudioSource(s.audio || "");

  $("scene").innerText = s.scene || "-";
  $("mood").innerText = s.mood || "-";
  $("prompt").innerText = s.prompt || "-";

  renderLabels(s.labels);
  renderOnomatopoeia(s.onomatopoeia);

  setProgress(0);
  resetStatuses();
  clearLog();

  appendLog(`sample selected: ${s.id || "unknown"}`);
  appendLog(`scene: ${s.scene || "-"}`);
  appendLog(`mood: ${s.mood || "-"}`);
}

function nextSample() {
  if (!samples.length) return;
  const nextIndex = (current + 1) % samples.length;
  stopAnalysis();
  showSample(nextIndex);
}

function stopAnalysis() {
  if (analysisTimer) {
    clearInterval(analysisTimer);
    analysisTimer = null;
  }
}

function startAnalysis() {
  if (!samples.length) {
    appendLog("サンプルが未読込です");
    return;
  }

  stopAnalysis();
  resetStatuses();
  clearLog();
  setProgress(0);

  const s = samples[current];

  appendLog(`analysis start: ${s.id || "unknown"}`);
  appendLog(`audio file: ${s.audio || "-"}`);

  let i = 0;

  analysisTimer = setInterval(() => {
    if (i > 0) {
      setStepStatus(i, "完了", "done");
    }

    if (i >= STEP_DEFS.length) {
      stopAnalysis();
      appendLog("analysis completed");
      return;
    }

    const step = STEP_DEFS[i];
    setStepStatus(i + 1, "実行中", "running");

    let detailMessage = `[STEP] ${step.label}`;

    if (step.key === "step-2") {
      const labels = normalizeArray(s.labels).join(", ");
      detailMessage += labels ? ` -> ${labels}` : "";
    }

    if (step.key === "step-3") {
      const scene = s.scene || "-";
      const mood = s.mood || "-";
      detailMessage += ` -> scene=${scene}, mood=${mood}`;
    }

    if (step.key === "step-4") {
      detailMessage += ` -> prompt ready`;
    }

    if (step.key === "step-5") {
      const ono = normalizeArray(s.onomatopoeia).join(" / ");
      detailMessage += ono ? ` -> onomatopoeia=${ono}` : "";
    }

    appendLog(detailMessage);

    const progress = Math.floor(((i + 1) / STEP_DEFS.length) * 100);
    setProgress(progress);

    i++;
  }, 900);
}

async function loadSamples() {
  try {
    appendLog("samples.json loading...");
    const res = await fetch("samples.json", { cache: "no-store" });

    if (!res.ok) {
      throw new Error(`HTTP ${res.status}`);
    }

    samples = await res.json();

    if (!Array.isArray(samples) || samples.length === 0) {
      throw new Error("samples.json is empty");
    }

    appendLog(`samples loaded: ${samples.length}`);
    showSample(0);
  } catch (err) {
    console.error(err);
    clearLog();
    appendLog(`ERROR: samples.json の読込に失敗しました: ${err.message}`);
    $("sampleTitle").innerText = "読み込み失敗";
    $("scene").innerText = "-";
    $("mood").innerText = "-";
    $("prompt").innerText = "samples.json を確認してください";
    $("onomatopoeia").innerText = "-";
    $("labels").innerHTML = `<span class="chip">読込失敗</span>`;
    setProgress(0);
    resetStatuses();
  }
}

window.startAnalysis = startAnalysis;
window.nextSample = nextSample;

window.addEventListener("DOMContentLoaded", () => {
  resetStatuses();
  setProgress(0);
  loadSamples();
});
